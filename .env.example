# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/traceform"

# Auth.js secret — generate with: npx auth secret
AUTH_SECRET="replace-with-generated-secret"

# Resend API key for magic link emails (https://resend.com)
AUTH_RESEND_KEY="re_your_key_here"
AUTH_EMAIL_FROM="noreply@yourdomain.com"

# App URL (set for production)
# AUTH_URL="https://your-app.vercel.app"
